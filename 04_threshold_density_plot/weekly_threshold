<div style="padding: 1rem 0;">
<div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 1.5rem; font-size: 12px; color: var(--color-text-secondary);" id="legend"></div>
<div style="position: relative; width: 100%; height: 420px;">
  <canvas id="densityChart" role="img" aria-label="KDE density plot of weekly thresholds per tag. Tags 71651 and 71662 have much higher thresholds (5–10) compared to other tags clustered near 0.">Weekly threshold density by tag.</canvas>
</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
const raw = [
  [61312,[0.5538,0.3441,0.4074,0.3828,2.1789,1.9757,1.3325,0.4752,0.5509]],
  [61325,[0.3093,0.2251,0.3398,0.3129,0.2326,0.1376,0.2209,0.3664,0.4834,0.3326]],
  [61327,[0.3164,0.2948,0.3071,0.2814,0.2821,1.0791,0.2904,0.4359,2.9763,1.5583,2.9197]],
  [61328,[0.1863,1.8476,0.1815,1.3365,0.1561,0.4029,0.7153,0.1585]],
  [71651,[5.6222,5.7589,5.6979,5.8374,5.9420,6.5556,5.5740,8.6409,7.2119,7.1076,7.7101,8.9810,7.8252,0.2338,0.7250]],
  [71653,[0.3664,0.3818,0.2780,0.3481,0.3025,0.1638,0.1577,0.3110,0.3026,0.3120,0.2944,0.3459,0.3145,0.3417,0.4447]],
  [71654,[0.3038,0.3303,0.4307,0.3340,0.2783,0.3261,0.3524,0.2933,0.3437,0.2963,3.0034,0.2838,0.2525,0.2700,1.3507]],
  [71662,[5.3530,9.2167,9.8556,7.7901,9.0118,9.2160,0.3456,0.4181,8.9623,7.7438]],
  [72012,[0.2323,0.2648,0.3046,0.3075,4.5253,1.6858,0.2653,0.1517,0.2210]],
];

const COLORS = [
  '#5C6BC0','#26A69A','#EF5350','#AB47BC',
  '#FFA726','#66BB6A','#29B6F6','#EC407A','#8D6E63'
];
const DASH = [[],[6,3],[3,3],[8,2],[4,4],[6,2,2,2],[],[3,6],[5,5]];

function kde(values, bandwidth, points) {
  return points.map(x => {
    const sum = values.reduce((acc, v) => {
      const u = (x - v) / bandwidth;
      return acc + Math.exp(-0.5 * u * u) / (Math.sqrt(2 * Math.PI));
    }, 0);
    return sum / (values.length * bandwidth);
  });
}

const allVals = raw.flatMap(([,v]) => v);
const xMin = 0, xMax = Math.ceil(Math.max(...allVals)) + 0.5;
const nPoints = 300;
const xs = Array.from({length: nPoints}, (_, i) => xMin + (xMax - xMin) * i / (nPoints - 1));

const datasets = raw.map(([tag, vals], i) => {
  const bw = 1.06 * Math.sqrt(vals.reduce((a,v)=>(a+(v-vals.reduce((s,x)=>s+x,0)/vals.length)**2),0)/vals.length) * Math.pow(vals.length, -0.2);
  const density = kde(vals, Math.max(bw, 0.15), xs);
  return {
    label: String(tag),
    data: xs.map((x, j) => ({x, y: density[j]})),
    borderColor: COLORS[i],
    backgroundColor: COLORS[i] + '18',
    borderWidth: 2,
    borderDash: DASH[i],
    fill: true,
    tension: 0.4,
    pointRadius: 0,
  };
});

const legendEl = document.getElementById('legend');
raw.forEach(([tag], i) => {
  const span = document.createElement('span');
  span.style.cssText = 'display:flex;align-items:center;gap:5px;';
  span.innerHTML = `<span style="width:22px;height:3px;background:${COLORS[i]};display:inline-block;border-radius:2px;"></span>${tag}`;
  legendEl.appendChild(span);
});

new Chart(document.getElementById('densityChart'), {
  type: 'line',
  data: {datasets},
  options: {
    responsive: true,
    maintainAspectRatio: false,
    interaction: {mode: 'index', intersect: false},
    plugins: {
      legend: {display: false},
      tooltip: {
        callbacks: {
          title: items => `threshold ≈ ${parseFloat(items[0].label).toFixed(2)}`,
          label: item => ` ${item.dataset.label}: density ${item.parsed.y.toFixed(3)}`
        }
      }
    },
    scales: {
      x: {
        type: 'linear',
        min: xMin,
        max: xMax,
        title: {display: true, text: 'Weekly threshold (std dev)', color: 'var(--color-text-secondary)', font: {size: 12}},
        ticks: {color: 'var(--color-text-secondary)', font: {size: 11}},
        grid: {color: 'var(--color-border-tertiary)'},
      },
      y: {
        title: {display: true, text: 'Density', color: 'var(--color-text-secondary)', font: {size: 12}},
        ticks: {color: 'var(--color-text-secondary)', font: {size: 11}, callback: v => v.toFixed(2)},
        grid: {color: 'var(--color-border-tertiary)'},
        min: 0,
      }
    }
  }
});
</script>
